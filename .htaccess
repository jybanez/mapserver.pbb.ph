RewriteEngine On

# Allow direct access to existing files and directories
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Route tile, boundary, health, and api endpoints to index.php
RewriteRule ^(tiles/.*|boundaries/.*|boundaries\.geojson|health|api/.*)$ index.php [L,QSA]
